generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String             @id @default(uuid())
  name           String
  email          String             @unique
  password       String
  role           UserRole           @default(CUSTOMER)
  phone          String
  avatar         String?
  isActive       Boolean            @default(true)
  isVerified     Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  likes          Like[]
  notifications  Notification[]
  orders         Order[]
  otpTokens      OtpToken?
  passwordResets PasswordReset[]
  providers      Provider?
  reviews        Review[]
  refreshTokens  UserRefreshToken[]
}

model Provider {
  id                 String                 @id @default(uuid())
  userId             String                 @unique
  status             ProviderStatus         @default(PENDING)
  experience         String?
  // bankName           String?
  // bankAccountNumber  String?
  // bankAccountName    String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  deletedAt          DateTime?
  orders             Order[]
  user               User                   @relation(fields: [userId], references: [id])
  availabilities     ProviderAvailability[]
  bundles            ProviderBundle[]
  coverages          ProviderCoverage[]
  portfolios         ProviderPortfolio[]
  roles              ProviderRole[]
  toppings           ProviderTopping[]
  reviews            Review[]
  wallet             Wallet?
  withdrawalRequests WithdrawalRequest[]

  @@index([userId])
}

model Role {
  id            String         @id @default(uuid())
  name          String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  providerRoles ProviderRole[]
}

model ProviderRole {
  id         String    @id @default(uuid())
  providerId String
  roleId     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  provider   Provider  @relation(fields: [providerId], references: [id])
  role       Role      @relation(fields: [roleId], references: [id])

  @@unique([providerId, roleId])
  @@index([providerId])
  @@index([roleId])
}

model Province {
  id        String    @id
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  regencies Regency[]
}

model Regency {
  id         String     @id
  provinceId String
  name       String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?
  districts  District[]
  province   Province   @relation(fields: [provinceId], references: [id])

  @@index([provinceId])
}

model District {
  id        String             @id
  regencyId String
  name      String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  deletedAt DateTime?
  regency   Regency            @relation(fields: [regencyId], references: [id])
  orders    Order[]
  coverages ProviderCoverage[]
  village   Village[]

  @@index([regencyId])
}

model Village {
  id         String    @id
  name       String
  districtId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt @default(now())
  deletedAt  DateTime?
  district   District  @relation(fields: [districtId], references: [id])
  @@index([districtId])
}

model ProviderCoverage {
  id         String    @id @default(uuid())
  providerId String
  districtId String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  district   District  @relation(fields: [districtId], references: [id])
  provider   Provider  @relation(fields: [providerId], references: [id])

  @@unique([providerId, districtId])
  @@index([providerId])
  @@index([districtId])
}

model ProviderAvailability {
  id          String    @id @default(uuid())
  providerId  String
  startDate   DateTime
  endDate     DateTime
  isAvailable Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  provider    Provider  @relation(fields: [providerId], references: [id])

  @@index([providerId])
}

model ProviderPortfolio {
  id          String    @id @default(uuid())
  providerId  String
  mediaUrl    String
  mediaId     String?   
  mediaType   String    @default("image") 
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  likes       Like[]
  provider    Provider  @relation(fields: [providerId], references: [id])

  @@index([providerId])
}

model ProviderBundle {
  id          String      @id @default(uuid())
  providerId  String
  name        String
  description String?
  price       Decimal     @db.Decimal(12, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  orderItems  OrderItem[]
  provider    Provider    @relation(fields: [providerId], references: [id])

  @@index([providerId])
}

model ProviderTopping {
  id                String             @id @default(uuid())
  providerId        String
  name              String
  description       String?
  price             Decimal            @db.Decimal(12, 2)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  orderItems        OrderItem[]
  orderItemToppings OrderItemTopping[]
  provider          Provider           @relation(fields: [providerId], references: [id])

  @@index([providerId])
}

model Order {
  id            String              @id @default(uuid())
  userId        String
  providerId    String
  districtId    String
  addressDetail String?
  eventDateTime DateTime
  status        OrderStatus         @default(PENDING)
  totalPrice    Decimal             @db.Decimal(12, 2)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?
  notifications Notification[]
  district      District            @relation(fields: [districtId], references: [id])
  provider      Provider            @relation(fields: [providerId], references: [id])
  user          User                @relation(fields: [userId], references: [id])
  orderItems    OrderItem[]
  payments      Payment[]
  review        Review?
  transactions  WalletTransaction[]

  @@index([userId])
  @@index([providerId])
  @@index([districtId])
  @@index([status])
}

model OrderItem {
  id        String             @id @default(uuid())
  orderId   String
  bundleId  String?
  toppingId String?
  price     Decimal            @db.Decimal(12, 2)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  deletedAt DateTime?
  bundle    ProviderBundle?    @relation(fields: [bundleId], references: [id])
  order     Order              @relation(fields: [orderId], references: [id])
  topping   ProviderTopping?   @relation(fields: [toppingId], references: [id])
  toppings  OrderItemTopping[]

  @@index([orderId])
  @@index([bundleId])
  @@index([toppingId])
}

model OrderItemTopping {
  id          String          @id @default(uuid())
  orderItemId String
  toppingId   String
  price       Decimal         @db.Decimal(12, 2)
  quantity    Int             @default(1)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  orderItem   OrderItem       @relation(fields: [orderItemId], references: [id])
  topping     ProviderTopping @relation(fields: [toppingId], references: [id])

  @@index([orderItemId])
  @@index([toppingId])
}

model PaymentCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  payments    Payment[]
}

model Payment {
  id            String          @id @default(uuid())
  orderId       String?
  categoryId    String
  amount        Decimal         @db.Decimal(12, 2)
  method        String
  transactionId String          @unique
  status        PaymentStatus   @default(PENDING)
  paidAt        DateTime?
  rawResponse   Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  category      PaymentCategory @relation(fields: [categoryId], references: [id])
  order         Order?          @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([categoryId])
  @@index([status])
}

model Review {
  id         String    @id @default(uuid())
  orderId    String    @unique
  userId     String
  providerId String
  rating     Int
  comment    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  order      Order     @relation(fields: [orderId], references: [id])
  provider   Provider  @relation(fields: [providerId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([providerId])
}

model Wallet {
  id                 String              @id @default(uuid())
  providerId         String              @unique
  currentBalance     Decimal             @default(0) @db.Decimal(12, 2)
  pendingBalance     Decimal             @default(0) @db.Decimal(12, 2)
  currency           String              @default("IDR")
  lastPayoutAt       DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  provider           Provider            @relation(fields: [providerId], references: [id])
  transactions       WalletTransaction[]
  withdrawalRequests WithdrawalRequest[]

  @@index([providerId])
}

model WalletTransaction {
  id                  String                  @id @default(uuid())
  walletId            String
  orderId             String?
  withdrawalRequestId String?
  amount              Decimal                 @db.Decimal(12, 2)
  type                WalletTransactionType
  status              WalletTransactionStatus @default(PENDING)
  description         String?
  externalTxId        String?
  retryCount          Int                     @default(0)
  lastAttemptAt       DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  deletedAt           DateTime?
  order               Order?                  @relation(fields: [orderId], references: [id])
  wallet              Wallet                  @relation(fields: [walletId], references: [id])
  withdrawalRequest   WithdrawalRequest?      @relation(fields: [withdrawalRequestId], references: [id])

  @@index([walletId])
  @@index([orderId])
  @@index([status])
}

model WithdrawalRequest {
  id                String              @id @default(uuid())
  providerId        String
  walletId          String
  amount            Decimal             @db.Decimal(12, 2)
  bankName          String
  bankAccountNumber String
  bankAccountName   String
  status            WithdrawalStatus    @default(PENDING)
  attemptedAt       DateTime?
  attemptCount      Int                 @default(0)
  note              String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  transactions      WalletTransaction[]
  provider          Provider            @relation(fields: [providerId], references: [id])
  wallet            Wallet              @relation(fields: [walletId], references: [id])

  @@index([providerId])
  @@index([walletId])
  @@index([status])
}

model OtpToken {
  id              String    @id @default(uuid())
  userId          String    @unique
  code            String
  expiresAt       DateTime
  isUsed          Boolean   @default(false)
  requestCount    Int       @default(0)
  requestResetAt  DateTime?
  lastRequestedAt DateTime?
  userAgent       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  user            User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model PasswordReset {
  id         String    @id @default(uuid())
  userId     String
  resetToken String    @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model UserRefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String
  expiredAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model TokenBlacklist {
  id        String    @id @default(uuid())
  token     String    @unique
  expiredAt DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model NotificationTemplate {
  id            String           @id @default(uuid())
  title         String
  type          NotificationType
  message       String           @db.VarChar(255)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?
  notifications Notification[]
}

model Notification {
  id         String                @id @default(uuid())
  userId     String
  templateId String?
  orderId    String?
  type       NotificationType
  message    String                @db.VarChar(255)
  isRead     Boolean               @default(false)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  deletedAt  DateTime?
  order      Order?                @relation(fields: [orderId], references: [id])
  template   NotificationTemplate? @relation(fields: [templateId], references: [id])
  user       User                  @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([templateId])
  @@index([orderId])
}

model Like {
  id          String            @id @default(uuid())
  userId      String
  portfolioId String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?
  portfolio   ProviderPortfolio @relation(fields: [portfolioId], references: [id])
  user        User              @relation(fields: [userId], references: [id])

  @@unique([userId, portfolioId])
  @@index([userId])
  @@index([portfolioId])
}

enum UserRole {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum ProviderStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum OrderStatus {
  PENDING
  PAID
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum NotificationType {
  ORDER_STATUS
  PAYMENT
  SYSTEM
  PROMO
  GREETING
}

enum WalletTransactionType {
  CREDIT
  DEBIT
  PENDING
  REFUND
  WITHDRAW
}

enum WalletTransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  APPROVED
  PAID
  REJECTED
}
