{
  "openapi": "3.0.3",
  "info": {
    "title": "Jepretin API",
    "description": "Dokumentasi API untuk Aplikasi JEPRETIN",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Local server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Register": {
        "type": "object",
        "required": ["name", "email", "password"],
        "properties": {
          "name": { "type": "string", "example": "John Doe" },
          "email": { "type": "string", "example": "johndoe@gmail.com" },
          "password": { "type": "string", "minLength": 6, "example": "123456" },
          "phone": { "type": "string", "example": "081234567890" }
        }
      },
      "Login": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "example": "johndoe@gmail.com" },
          "password": { "type": "string", "example": "123456" }
        }
      },
      "ForgotPassword": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": { "type": "string", "example": "johndoe@gmail.com" }
        }
      },
      "ResetPassword": {
        "type": "object",
        "required": ["token", "password", "confirmPassword"],
        "properties": {
          "token": { "type": "string", "example": "JWT_RESET_TOKEN" },
          "password": { "type": "string", "example": "newPassword123" },
          "confirmPassword": { "type": "string", "example": "newPassword123" }
        }
      },
      "VerifyOtp": {
        "type": "object",
        "required": ["email", "otpCode"],
        "properties": {
          "email": { "type": "string", "example": "johndoe@gmail.com" },
          "otpCode": { "type": "string", "example": "123456" }
        }
      },
      "ResendOtp": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": { "type": "string", "example": "johndoe@gmail.com" }
        }
      },
      "ProviderRegister": {
        "type": "object",
        "required": [
          "experience",
          "bankName",
          "bankAccountNumber",
          "bankAccountName"
        ],
        "properties": {
          "experience": {
            "type": "string",
            "example": "5 tahun pengalaman fotografi"
          },
          "bankName": { "type": "string", "example": "BCA" },
          "bankAccountNumber": { "type": "string", "example": "1234567890" },
          "bankAccountName": { "type": "string", "example": "John Doe" }
        }
      },
      "UserUpdate": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "example": "Updated Name" },
          "phone": { "type": "string", "example": "081298765432" }
        }
      },
      "ProviderUpdate": {
        "type": "object",
        "properties": {
          "experience": {
            "type": "string",
            "example": "7 tahun pengalaman fotografi"
          },
          "bankName": { "type": "string", "example": "Mandiri" },
          "bankAccountNumber": { "type": "string", "example": "9876543210" },
          "bankAccountName": { "type": "string", "example": "Jane Doe" }
        }
      }
    }
  },
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register user baru",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Register" }
            }
          }
        },
        "responses": {
          "201": { "description": "Registrasi berhasil, OTP dikirim ke email" },
          "409": { "description": "Email sudah digunakan" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Login" }
            }
          }
        },
        "responses": {
          "200": { "description": "Login berhasil, token JWT dikembalikan" },
          "401": { "description": "Email atau password salah" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout user (Blacklist Token)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Logout berhasil, token di-blacklist" },
          "401": { "description": "Token tidak valid atau tidak ada" }
        }
      }
    },
    "/auth/otp/verify": {
      "post": {
        "tags": ["Auth"],
        "summary": "Verifikasi OTP",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/VerifyOtp" }
            }
          }
        },
        "responses": {
          "200": { "description": "OTP valid, user terverifikasi" },
          "400": { "description": "OTP tidak valid atau expired" }
        }
      }
    },
    "/auth/otp/resend": {
      "post": {
        "tags": ["Auth"],
        "summary": "Kirim ulang OTP",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ResendOtp" }
            }
          }
        },
        "responses": {
          "200": { "description": "OTP baru berhasil dikirim" }
        }
      }
    },
    "/auth/forgot-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Lupa password - kirim link reset ke email",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ForgotPassword" }
            }
          }
        },
        "responses": {
          "200": { "description": "Link reset password dikirim ke email" },
          "404": { "description": "User tidak ditemukan" }
        }
      }
    },
    "/auth/reset-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Reset password menggunakan token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ResetPassword" }
            }
          }
        },
        "responses": {
          "200": { "description": "Password berhasil direset" },
          "400": {
            "description": "Token tidak valid atau password tidak cocok"
          }
        }
      }
    },
    "/user/all-user": {
      "get": {
        "tags": ["User"],
        "summary": "Ambil semua user",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Daftar user berhasil diambil" }
        }
      }
    },
    "/user/get-user": {
      "get": {
        "tags": ["User"],
        "summary": "Ambil detail user yang sedang login",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "User ditemukan" }
        }
      }
    },
    "/user/update-user": {
      "put": {
        "tags": ["User"],
        "summary": "Edit data user",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UserUpdate" }
            }
          }
        },
        "responses": {
          "200": { "description": "User berhasil diperbarui" }
        }
      }
    },
    "/user/delete-user": {
      "delete": {
        "tags": ["User"],
        "summary": "Hapus user",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "User berhasil dihapus" }
        }
      }
    },
    "/provider/all-provider": {
      "get": {
        "tags": ["Provider"],
        "summary": "Ambil semua provider",
        "responses": {
          "200": { "description": "Daftar provider berhasil diambil" }
        }
      }
    },
    "/provider/provider": {
      "post": {
        "tags": ["Provider"],
        "summary": "Registrasi provider baru",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ProviderRegister" }
            }
          }
        },
        "responses": {
          "200": { "description": "Provider berhasil diregistrasi" }
        }
      }
    },
    "/provider/get-provider": {
      "get": {
        "tags": ["Provider"],
        "summary": "Ambil provider milik user yang sedang login",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Provider ditemukan" }
        }
      }
    },
    "/provider/update-provider": {
      "put": {
        "tags": ["Provider"],
        "summary": "Edit provider milik user yang sedang login",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ProviderUpdate" }
            }
          }
        },
        "responses": {
          "200": { "description": "Provider berhasil diperbarui" }
        }
      }
    },
    "/provider/delete-provider": {
      "delete": {
        "tags": ["Provider"],
        "summary": "Hapus provider milik user yang sedang login",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Provider berhasil dihapus" }
        }
      }
    },
    "/wilayah/provinces": {
      "get": {
        "tags": ["Wilayah"],
        "summary": "Ambil semua provinsi",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Berhasil mengambil data provinsi" }
        }
      }
    },
    "/wilayah/regencies/{provinceId}": {
      "get": {
        "tags": ["Wilayah"],
        "summary": "Ambil semua kabupaten/kota berdasarkan ID provinsi",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "provinceId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "35"
          }
        ],
        "responses": {
          "200": { "description": "Berhasil mengambil data kabupaten/kota" }
        }
      }
    },
    "/wilayah/districts/{regencyId}": {
      "get": {
        "tags": ["Wilayah"],
        "summary": "Ambil semua kecamatan berdasarkan ID kabupaten/kota",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "regencyId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "3578"
          }
        ],
        "responses": {
          "200": { "description": "Berhasil mengambil data kecamatan" }
        }
      }
    },
    "/wilayah/villages/{districtId}": {
      "get": {
        "tags": ["Wilayah"],
        "summary": "Ambil semua desa berdasarkan ID kecamatan",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "districtId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "3578010"
          }
        ],
        "responses": {
          "200": { "description": "Berhasil mengambil data desa" }
        }
      }
    }
  }
}
